# This gitignore is a whitelist. Inspired by https://rgbcu.be/blog/gitignore

*

!.gitignore
!.golangci.yml
!AGENTS.md
!LICENSE.md

# Root-level source and docs stay explicit; recursive allowlists are intentional for nested command and test paths.
!*.md
!*.go
!searchDeciderPrompt.txt
!cmd/
!cmd/**/*

!Dockerfile
!config-example.yaml
!docker-compose.yaml
!go.mod
!go.sum
!render.yaml
